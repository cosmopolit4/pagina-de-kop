# ── SUPABASE ──
# Obtené estos valores en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── ADMIN ──
# Cambiá esto por tu contraseña real (mínimo 12 caracteres)
ADMIN_PASSWORD=TuContraseñaSegura2025!

# ── JWT SECRET ──
# Cadena aleatoria larga para firmar tokens (podés generar una en: jwtsecret.com)
